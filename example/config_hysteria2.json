{
  "Log": {
    "Level": "info",
    "Output": ""
  },
  "Cores": [
    {
      "Type": "hysteria2",
      "Log": {
        "Level": "error"
      }
    }
  ],
  "Nodes": [
    {
      "Name": "hysteria2-demo",
      "Core": "hysteria2",
      "ApiHost": "https://panel.example.com",
      "ApiKey": "your-api-key",
      "NodeID": 1,
      "NodeType": "hysteria2",
      "Timeout": 30,
      "ListenIP": "0.0.0.0",
      "SendIP": "0.0.0.0",
      "CertConfig": {
        "CertMode": "file",
        "RejectUnknownSni": false,
        "CertDomain": "hy2.example.com",
        "CertFile": "/etc/V2bX/fullchain.cer",
        "KeyFile": "/etc/V2bX/cert.key",
        "Provider": "cloudflare",
        "Email": "admin@example.com",
        "DNSEnv": {
          "EnvName": "env1"
        }
      }
    }
  ]
}
